# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Vertex AI (RAG embeddings + Gemini agents) ---
# Auth is via gcloud Application Default Credentials (ADC) — no API key in Vertex mode.
#   gcloud auth application-default login --no-launch-browser
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Tavily (web search tool) ---
TAVILY_API_KEY=tvly-...

# --- Optional: Gemini Developer API key ---
# Only used if GOOGLE_GENAI_USE_VERTEXAI=false. The google-genai SDK reads
# GOOGLE_API_KEY (NOT the old GEMINI_API_KEY name).
# GOOGLE_API_KEY=AIza...
